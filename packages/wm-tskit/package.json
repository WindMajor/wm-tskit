{
  "name": "wm-tskit",
  "version": "0.0.1",
  "description": "TypeScript 通用工具函数仓库，能力积木集合（全家桶）",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "keywords": ["typescript", "utils", "toolkit", "helpers", "types"],
  "license": "MIT",
  "dependencies": {
    "wm-types": "workspace:*",
    "wm-utils": "workspace:*",
    "wm-algorithm": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
